# Dependencies
node_modules/

# Build output
dist/

# Scraper output (data, PDFs, state)
output/

# SQLite database + WAL sidecars (run artifacts, never committed)
*.db
*.db-wal
*.db-shm

# Logs
*.log

# Environment
.env

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local recon scratch (not part of the deliverable)
recon-pj/
recon-pj.sh

# Local scratch / exploration (not part of the deliverable)
/test-*.ts
/code-review-findings.json

# --- Committed sample run of PJ (so a reviewer without a Peru VPN can still
# inspect real output). Keep the SQLite DB + the JSON/CSV exports; never commit
# the bulky PDFs or the WAL sidecars. Negations come AFTER the *.db rule above. ---
!sample/
!sample/documents.db
!sample/documents.json
!sample/documents.csv
!sample/state.json
!sample/report.json

# A full run downloads hundreds of PDFs into sample/pdfs/ (~72 MB) — too heavy
# to commit. We keep a handful of REAL ones so a reviewer can open them and
# confirm the download path works end to end. Everything else stays ignored.
sample/pdfs/*
!sample/pdfs/Apelación-000169-2025__Resolucion_10_20260708160131000621498.pdf
!sample/pdfs/Apelación-000373-2025__Resolucion_10_20260708142912000031643.pdf
!sample/pdfs/Apelación-000389-2025__Resolucion_10_20260708131423000722299.pdf
!sample/pdfs/Apelación-000474-2025__Resolucion_10_2026070812291100073954.pdf
!sample/pdfs/Apelación-001231-2025__Resolucion_12_20260701151627000909781.pdf
